# =============================================
# Rename this file to .env and fill in values
# =============================================

# From Meta Developer Dashboard → WhatsApp → API Setup
WHATSAPP_TOKEN=paste_your_meta_access_token_here
PHONE_NUMBER_ID=paste_your_phone_number_id_here

# Any random secret string — you choose this yourself
VERIFY_TOKEN=mysecret123

# From console.groq.com (FREE — no credit card needed)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# YOUR WhatsApp number with country code (no + sign)
# India example: 919876543210
OWNER_PHONE=919876543210

PORT=3000
